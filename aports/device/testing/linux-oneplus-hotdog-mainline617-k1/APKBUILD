# Maintainer: Sr-0w <Sr-0w@users.noreply.github.com>
# Forensic build-input reproduction of the historical K1 mainline 6.17 Image:
#   48ac790a9f15dbf3e976557d1baee6a72b847fefed17fed9e700424d91e3fa83
#
# This package intentionally does not promise a byte-identical Image. The
# historical artifact encoded local build metadata such as timestamp, toolchain
# versions, build counter, and a dirty git release suffix.

pkgname=linux-oneplus-hotdog-mainline617-k1
pkgver=6.17.0
pkgrel=0
pkgdesc="Forensic mainline 6.17 K1 kernel reproduction for OnePlus 7T Pro"
arch="aarch64"
_carch="arm64"
_flavor="oneplus-hotdog-mainline617-k1"
url="https://gitlab.postmarketos.org/soc/qualcomm-sm8150/linux"
license="GPL-2.0-only"
options="!strip !check !tracedeps
	pmb:cross-native
	pmb:kconfigcheck-nftables
	"
makedepends="
	bash
	bc
	bison
	clang
	findutils
	flex
	lld
	llvm
	openssl-dev
	perl
	python3
	zstd
"

_repo="linux"
_commit="379d8fe35c7ca685a650bd82fd023af0ea3f0de0"
_config="config-$_flavor.$arch"
source="
	$pkgname-$_commit.tar.bz2::$url/-/archive/$_commit/$_repo-$_commit.tar.bz2
	$_config
	0001-arm64-hotdog-use-android-entry-layout.patch
	0002-input-fts-fix-strict-prototypes.patch
	0003-power-supply-idtp9418-include-gpio-consumer.patch
	0004-arm64-dts-qcom-add-oneplus-hotdog.patch
"
builddir="$srcdir/$_repo-$_commit"

prepare() {
	default_prepare
	cp "$srcdir/$_config" .config
	make ARCH="$_carch" LLVM=1 olddefconfig
}

build() {
	unset LDFLAGS
	make ARCH="$_carch" LLVM=1 \
		KBUILD_BUILD_VERSION="$((pkgrel + 1))-$_flavor" \
		Image modules dtbs
}

package() {
	mkdir -p "$pkgdir"/boot

	install -Dm644 "$builddir/arch/$_carch/boot/Image" \
		"$pkgdir/boot/vmlinuz"

	make modules_install dtbs_install \
		ARCH="$_carch" \
		LLVM=1 \
		INSTALL_PATH="$pkgdir"/boot/ \
		INSTALL_MOD_PATH="$pkgdir/usr" \
		INSTALL_MOD_STRIP=1 \
		INSTALL_DTBS_PATH="$pkgdir"/boot/dtbs
	rm -f "$pkgdir"/usr/lib/modules/*/build "$pkgdir"/usr/lib/modules/*/source

	install -D "$builddir"/include/config/kernel.release \
		"$pkgdir"/usr/share/kernel/$_flavor/kernel.release
}

