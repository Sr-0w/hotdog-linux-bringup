# Reference: <https://postmarketos.org/devicepkg>
# Maintainer: Igor Belwon <igor.belwon@mentallysanemainliners.org>

pkgname=device-oneplus-hotdog
pkgdesc="OnePlus 7T Pro"
pkgver=1
pkgrel=2
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
install="$pkgname.post-install"
depends="
	postmarketos-base
	mkbootimg
	linux-oneplus-hotdog-lineage414
	mesa-vulkan-freedreno
	swclock-offset
"
makedepends="devicepkg-dev"
source="
	deviceinfo
	30-initramfs-firmware.files
	51-qcom-sm8150.lua
	$pkgname.post-install
	90-hotdog-bringup-doas.conf
	$pkgname-nonfree-firmware.post-install
	modules-initfs
"

subpackages="
	$pkgname-nonfree-firmware:nonfree_firmware
	$pkgname-mainline-firmware:mainline_firmware
	$pkgname-wireplumber:wireplumber
	$pkgname-bringup:bringup
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
}

bringup() {
	pkgdesc="Development-only doas policy for dedicated bring-up phones"
	depends="doas"
	install -Dm0440 "$srcdir/90-hotdog-bringup-doas.conf" \
		"$subpkgdir/etc/doas.d/90-hotdog-bringup.conf"
}

mainline_firmware() {
	pkgdesc="Firmware support packages for mainline kernel"
	depends="firmware-oneplus-hotdog-adreno"
	install_if="linux-oneplus-hotdog-lineage414 $pkgname-nonfree-firmware"
	mkdir "$subpkgdir"

	install -Dm644 "$srcdir/30-initramfs-firmware.files" \
		"$subpkgdir/etc/postmarketos-mkinitfs/files/30-initramfs-firmware.files"
}

nonfree_firmware() {
	pkgdesc="Firmware for GPU, Touchscreen, Audio, Bluetooth, WiFi, etc."
	depends="
		firmware-oneplus-hotdog-adreno
		firmware-oneplus-hotdog-adsp
		firmware-oneplus-hotdog-cdsp
		firmware-oneplus-hotdog-modem
		firmware-oneplus-hotdog-wlan
		firmware-oneplus-hotdog-bluetooth
		firmware-oneplus-hotdog-venus
		msm-modem
		pd-mapper
		pd-mapper-openrc
		tqftpserv
		tqftpserv-openrc
		bootmac
		alsa-utils
		"
	install="$subpkgname.post-install"
	mkdir "$subpkgdir"
}

wireplumber() {
	install -Dm644 "$srcdir"/51-qcom-sm8150.lua \
		-t "$subpkgdir"/usr/share/wireplumber/main.lua.d
}

