f9a54da9bbdbc75fa58297b38c0f912acae2b9916e0d5d1fdab8add68c92f5828dec45ab11da95f7621be971f13ff7b45f8f04fca86e00b8ffd863cc305526d4  config-oneplus-hotdog-lineage414.aarch64
5d4bee9d38662642ef96cfefc0def0b427dca3ea71e7bd24c04d2ab16661e39d4cb61d2ef42d58a9008018ddb021d6ae15a116b8fa0e642c3a2790456c3dbc94  stock-hotdog-dtbpack.dtb
"
