# Reference: <https://postmarketos.org/vendorkernel>
# Temporary boot-proven downstream kernel for oneplus-hotdog bring-up.

pkgname=linux-oneplus-hotdog-lineage414
pkgver=4.14.357_git20260703
pkgrel=3
pkgdesc="LineageOS downstream kernel for OnePlus 7T Pro"
arch="aarch64"
_carch="arm64"
_flavor="oneplus-hotdog-lineage414"
url="https://github.com/LineageOS/android_kernel_oneplus_sm8150"
license="GPL-2.0-only"
options="!strip !check !tracedeps pmb:cross-native"
makedepends="
	bash
	bc
	bison
	clang
	devicepkg-dev
	findutils
	flex
	lld
	linux-headers
	llvm
	openssl-dev
	perl
	xz
	"

_repository="android_kernel_oneplus_sm8150"
_commit="6ecfabed032b68a8f0a0fd003cf5fbfb6d672acb"
_config="config-$_flavor.aarch64"
source="
	$pkgname-$_commit.tar.gz::https://github.com/LineageOS/$_repository/archive/$_commit.tar.gz
	$_config
	stock-hotdog-dtbpack.dtb
	"
builddir="$srcdir/$_repository-$_commit"
_outdir="$srcdir/build-$_flavor"

_makeargs="
	O=$_outdir
	ARCH=$_carch
	LLVM=1
	LLVM_IAS=1
	CROSS_COMPILE=aarch64-linux-gnu-
	CLANG_TRIPLE=aarch64-linux-gnu-
	KCFLAGS=-Wno-error=implicit-enum-enum-cast
	KBUILD_BUILD_VERSION=$((pkgrel + 1))-postmarketOS
	"

prepare() {
	default_prepare
	mkdir -p "$_outdir"
	cp "$srcdir/$_config" "$_outdir/.config"
	make $_makeargs olddefconfig
}

build() {
	unset LDFLAGS
	make $_makeargs Image modules
}

package() {
	install -Dm644 "$_outdir/arch/$_carch/boot/Image" \
		"$pkgdir/boot/vmlinuz"

	# Boot-proven stock DTB pack with dtb_idx=12 instrumented for
	# simplefb and an explicit /chosen ranges mapping.
	install -Dm644 "$srcdir/stock-hotdog-dtbpack.dtb" \
		"$pkgdir/boot/dtbs/qcom/sm8150-oneplus-hotdog.dtb"

	make $_makeargs \
		INSTALL_MOD_STRIP=1 \
		INSTALL_MOD_PATH="$pkgdir" \
		modules_install
	rm -f "$pkgdir"/lib/modules/*/build "$pkgdir"/lib/modules/*/source

	install -D "$_outdir/include/config/kernel.release" \
		"$pkgdir/usr/share/kernel/$_flavor/kernel.release"
}

sha512sums="
