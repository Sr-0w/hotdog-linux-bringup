* text=auto eol=lf
*.patch text eol=lf whitespace=-space-before-tab

# Light Git LFS readiness for future binary drops.
*.img filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.apk filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.dtb filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.tar.xz filter=lfs diff=lfs merge=lfs -text

# Existing Git blob; do not require Git LFS smudge/filter support for clones.
aports/device/testing/linux-oneplus-hotdog-lineage414/stock-hotdog-dtbpack.dtb -filter -diff -merge -text
