From: Sr-0w <Sr-0w@users.noreply.github.com>
Date: Mon, 13 Jul 2026 00:00:00 +0000
Subject: [PATCH] arm64: hotdog: reset after initial idmap creation

This diagnostic checkpoint runs after record_mmu_state(), preserve_boot_args(),
the early stack setup, and __pi_create_init_idmap(). It then requests PSCI
SYSTEM_RESET. Comparing it with the primary_entry reset probe isolates failures
inside the first pre-MMU setup block.

Do not ship this patch in a normal kernel.
---
 arch/arm64/kernel/head.S | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/arch/arm64/kernel/head.S b/arch/arm64/kernel/head.S
--- a/arch/arm64/kernel/head.S
+++ b/arch/arm64/kernel/head.S
@@ -107,6 +107,16 @@ SYM_CODE_START(primary_entry)
 	mov	x1, xzr
 	bl	__pi_create_init_idmap
 
+	/* Hotdog checkpoint: prove execution through initial idmap creation. */
+	movz	x0, #0x0009
+	movk	x0, #0x8400, lsl #16
+	mov	x1, xzr
+	mov	x2, xzr
+	mov	x3, xzr
+	smc	#0
+9:	wfe
+	b	9b
+
 	/*
 	 * If the page tables have been populated with non-cacheable
 	 * accesses (MMU disabled), invalidate those tables again to
