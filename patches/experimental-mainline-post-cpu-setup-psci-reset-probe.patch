From: Sr-0w <Sr-0w@users.noreply.github.com>
Date: Mon, 13 Jul 2026 00:00:00 +0000
Subject: [PATCH] arm64: hotdog: reset after early CPU setup

This diagnostic checkpoint requests PSCI SYSTEM_RESET after initial idmap
creation, cache maintenance, init_kernel_el(), and __cpu_setup(), immediately
before __primary_switch enables the final early translation regime.

Do not ship this patch in a normal kernel.
---
 arch/arm64/kernel/head.S | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/arch/arm64/kernel/head.S b/arch/arm64/kernel/head.S
--- a/arch/arm64/kernel/head.S
+++ b/arch/arm64/kernel/head.S
@@ -138,4 +138,14 @@ SYM_CODE_START(primary_entry)
 	 */
 	bl	__cpu_setup			// initialise processor
+
+	/* Hotdog checkpoint: prove execution through CPU setup before the MMU. */
+	movz	x0, #0x0009
+	movk	x0, #0x8400, lsl #16
+	mov	x1, xzr
+	mov	x2, xzr
+	mov	x3, xzr
+	smc	#0
+9:	wfe
+	b	9b
 	b	__primary_switch
 SYM_CODE_END(primary_entry)
