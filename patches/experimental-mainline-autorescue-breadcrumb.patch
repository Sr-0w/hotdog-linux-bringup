--- a/init/main.c
+++ b/init/main.c
@@ -117,6 +117,36 @@
 
 static int kernel_init(void *);
 
+#define HOTDOG_EARLY_BREADCRUMB_MAGIC	0x32454448
+
+struct hotdog_early_breadcrumb {
+	u32 magic;
+	u32 version;
+	u32 stage;
+	u32 stage_inverse;
+	u32 detail;
+	u32 detail_inverse;
+	u32 reserved[10];
+};
+
+extern struct hotdog_early_breadcrumb hotdog_early_breadcrumb;
+
+static __always_inline void hotdog_mark_start_kernel_stage(u32 stage,
+						    u32 detail)
+{
+	struct hotdog_early_breadcrumb *breadcrumb =
+		&hotdog_early_breadcrumb;
+
+	WRITE_ONCE(breadcrumb->magic, HOTDOG_EARLY_BREADCRUMB_MAGIC);
+	WRITE_ONCE(breadcrumb->version, 1);
+	WRITE_ONCE(breadcrumb->stage, stage);
+	WRITE_ONCE(breadcrumb->stage_inverse, ~stage);
+	WRITE_ONCE(breadcrumb->detail, detail);
+	WRITE_ONCE(breadcrumb->detail_inverse, ~detail);
+	dcache_clean_poc((unsigned long)breadcrumb,
+			 (unsigned long)breadcrumb + sizeof(*breadcrumb));
+}
