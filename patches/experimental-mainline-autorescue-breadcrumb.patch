+/*
+ * This breadcrumb lives inside the Image, so both the identity mapping and
+ * the final kernel mapping can update it before normal physical mappings are
+ * available. The host derives its physical address from the Image load
+ * address and the symbol offset reported by nm.
+ */
+	.macro	hotdog_mark_early_stage stage, cached=0
+	adr_l	x9, hotdog_early_breadcrumb
+	movz	w10, #0x4448
+	movk	w10, #0x3245, lsl #16		// "HDE2"
+	str	w10, [x9, #0x00]
+	mov	w10, #1
+	str	w10, [x9, #0x04]		// format version
+	mov	w10, #\stage
+	str	w10, [x9, #0x08]
+	mvn	w10, w10
+	str	w10, [x9, #0x0c]		// torn-write guard
+	.if \cached
+	dc	cvac, x9
+	dsb	sy
+	.else
+	dmb	sy
+	dc	ivac, x9
+	.endif
+	.endm
+
 /*
  * Kernel startup entry point.
  * ---------------------------
@@ -58,9 +84,14 @@
 	/*
 	 * DO NOT MODIFY. Image header expected by Linux boot-loaders.
 	 */
+#ifdef CONFIG_EFI
 	efi_signature_nop			// special NOP to identity as PE/COFF executable
 	b	primary_entry			// branch to kernel start, magic
-	.quad	0				// Image load offset from start of RAM, little-endian
+#else
+	b	primary_entry			// stock Android entry layout
+	.long	0				// reserved / stock-compatible code1
+#endif
+	.quad	0x00080000			// Image load offset from start of RAM, little-endian
 	le64sym	_kernel_size_le			// Effective size of kernel image, little-endian
 	le64sym	_kernel_flags_le		// Informative flags, little-endian
 	.quad	0				// reserved
@@ -127,6 +158,40 @@ SYM_CODE_START(primary_entry)
 	 * the TCR will have been set.
 	 */
 	bl	__cpu_setup			// initialise processor
+	hotdog_mark_early_stage 10
+
+	/*
+	 * Direct-boot diagnostic safety net. Preserve an exact early-stage
+	 * breadcrumb, ask the downstream boot chain to enter fastboot after a
+	 * reset, then arm the APSS watchdog for 30 seconds. init/main.c updates
+	 * the breadcrumb and clears both safety devices after all initcalls.
+	 */
+	movz	x9, #0xf000
+	movk	x9, #0xa9bf, lsl #16		// unused tail page of ramoops
+	movz	w10, #0x4f47
+	movk	w10, #0x4844, lsl #16		// "HDOG"
+	str	w10, [x9, #0x00]
+	mov	w10, #1
+	str	w10, [x9, #0x04]		// stage: primary_entry
+
+	movz	x9, #0xf65c
+	movk	x9, #0x146b, lsl #16		// IMEM restart_reason
+	movz	w10, #0x5500
+	movk	w10, #0x7766, lsl #16		// bootloader on next reset
+	str	w10, [x9]
+
+	movz	x9, #0x17c1, lsl #16		// APSS WDT: 0x17c10000
+	str	wzr, [x9, #0x08]		// disable
+	mov	w10, #1
+	str	w10, [x9, #0x04]		// reset counter
+	movz	w10, #0xfe88
+	movk	w10, #0x000e, lsl #16		// 30 * 32764 ticks
+	str	w10, [x9, #0x10]		// bark time
+	str	w10, [x9, #0x14]		// bite time
+	mov	w10, #1
+	str	w10, [x9, #0x08]		// enable
+	dsb	sy
+
 	b	__primary_switch
 SYM_CODE_END(primary_entry)
 
