  *   x0 = __pa(KERNEL_START)
  */
 SYM_FUNC_START_LOCAL(__primary_switched)
+	hotdog_mark_early_stage 50, 1
 	adr_l	x4, init_task
 	init_cpu_task x4, x5, x6
 
