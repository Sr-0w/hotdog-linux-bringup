+#define HOTDOG_APSS_WDT_PHYS		0x17c10000
+#define HOTDOG_APSS_WDT_SIZE		0x1000
+#define HOTDOG_APSS_WDT_RATE		32764
+#define HOTDOG_APSS_WDT_TIMEOUT_SEC	30
+#define HOTDOG_APSS_WDT_RST		0x04
+#define HOTDOG_APSS_WDT_ENABLE		0x08
+#define HOTDOG_APSS_WDT_BARK_TIME	0x10
+#define HOTDOG_APSS_WDT_BITE_TIME	0x14
+#define HOTDOG_IMEM_REASON_PHYS		0x146bf65c
+#define HOTDOG_BREADCRUMB_PHYS		0xa9bff000
+#define HOTDOG_BREADCRUMB_MAGIC		0x48444f47
+
+static void __iomem *hotdog_apss_wdt_base;
+static void __iomem *hotdog_imem_reason;
+static void __iomem *hotdog_breadcrumb;
+static u32 hotdog_initcall_index;
+
+static void __init hotdog_write_breadcrumb(u32 stage, u32 level,
+					   initcall_t call)
+{
+	u64 address = (unsigned long)call;
+
+	if (!hotdog_breadcrumb)
+		return;
+
+	writel(HOTDOG_BREADCRUMB_MAGIC, hotdog_breadcrumb + 0x00);
+	writel(stage, hotdog_breadcrumb + 0x04);
+	writel(level, hotdog_breadcrumb + 0x08);
+	writel(hotdog_initcall_index, hotdog_breadcrumb + 0x0c);
+	writel(lower_32_bits(address), hotdog_breadcrumb + 0x10);
+	writel(upper_32_bits(address), hotdog_breadcrumb + 0x14);
+	wmb();
+}
+
+static void __init hotdog_prepare_initcall_diagnostics(void)
+{
+	u32 ticks = HOTDOG_APSS_WDT_TIMEOUT_SEC * HOTDOG_APSS_WDT_RATE;
+
+	hotdog_breadcrumb = ioremap(HOTDOG_BREADCRUMB_PHYS, SZ_4K);
+	hotdog_imem_reason = ioremap(HOTDOG_IMEM_REASON_PHYS, sizeof(u32));
+	hotdog_apss_wdt_base = ioremap(HOTDOG_APSS_WDT_PHYS,
+						 HOTDOG_APSS_WDT_SIZE);
+	hotdog_write_breadcrumb(2, U32_MAX, NULL);
+
+	if (hotdog_imem_reason)
+		writel(0x77665500, hotdog_imem_reason);
+
+	if (hotdog_apss_wdt_base) {
+		writel(0, hotdog_apss_wdt_base + HOTDOG_APSS_WDT_ENABLE);
+		writel(1, hotdog_apss_wdt_base + HOTDOG_APSS_WDT_RST);
+		writel(ticks, hotdog_apss_wdt_base + HOTDOG_APSS_WDT_BARK_TIME);
+		writel(ticks, hotdog_apss_wdt_base + HOTDOG_APSS_WDT_BITE_TIME);
+		writel(1, hotdog_apss_wdt_base + HOTDOG_APSS_WDT_ENABLE);
+		wmb();
+	}
+
+	pr_emerg("HOTDOG: direct-boot watchdog and persistent initcall trace armed\n");
+}
+
+static void __init hotdog_finish_initcall_diagnostics(void)
+{
+	hotdog_write_breadcrumb(5, U32_MAX, NULL);
+
+	if (hotdog_apss_wdt_base) {
+		writel(0, hotdog_apss_wdt_base + HOTDOG_APSS_WDT_ENABLE);
+		wmb();
+	}
+	if (hotdog_imem_reason) {
+		writel(0x77665501, hotdog_imem_reason);
+		wmb();
+	}
+
+	pr_emerg("HOTDOG: initcalls completed; diagnostic watchdog disarmed\n");
+}
+
 static void __init do_initcall_level(int level, char *command_line)
 {
 	initcall_entry_t *fn;
+	initcall_t call;
 
 	parse_args(initcall_level_names[level],
 		   command_line, __start___param,
@@ -1327,8 +1442,13 @@ static void __init do_initcall_level(int level, char *command_line)
 		   NULL, ignore_unknown_bootoption);
 
 	do_trace_initcall_level(initcall_level_names[level]);
-	for (fn = initcall_levels[level]; fn < initcall_levels[level+1]; fn++)
-		do_one_initcall(initcall_from_entry(fn));
+	for (fn = initcall_levels[level]; fn < initcall_levels[level+1]; fn++) {
+		call = initcall_from_entry(fn);
+		hotdog_write_breadcrumb(3, level, call);
+		do_one_initcall(call);
+		hotdog_write_breadcrumb(4, level, call);
+		hotdog_initcall_index++;
+	}
 }
 
 static void __init do_initcalls(void)
@@ -1337,6 +1457,9 @@ static void __init do_initcalls(void)
 	size_t len = saved_command_line_len + 1;
 	char *command_line;
 
+	hotdog_mark_start_kernel_stage(200, 0);
+	hotdog_prepare_initcall_diagnostics();
+
 	command_line = kzalloc(len, GFP_KERNEL);
 	if (!command_line)
 		panic("%s: Failed to allocate %zu bytes\n", __func__, len);
@@ -1347,6 +1470,7 @@ static void __init do_initcalls(void)
 		do_initcall_level(level, command_line);
 	}
 
+	hotdog_finish_initcall_diagnostics();
 	kfree(command_line);
 }
 
